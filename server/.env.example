PORT=6601

# LLM provider: 'local' or 'qianwen'
LLM_PROVIDER=qianwen
QIANWEN_API_KEY=
QIANWEN_MODEL=qwen-plus
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# CORS 白名单（逗号分隔）。不设置则允许所有来源。
# iOS Capacitor App 必须加入 capacitor://localhost
# 示例：ALLOWED_ORIGINS=https://your-domain.com,capacitor://localhost
ALLOWED_ORIGINS=
